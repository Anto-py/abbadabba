generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String?
  image           String?
  marginalTaxRate Float         @default(45)
  homeAddress     String?
  createdAt       DateTime      @default(now())
  transactions    Transaction[]
  categories      Category[]
  yearSheets      YearSheet[]
  tripRates       TripRate[]
  trips           Trip[]
}

model YearSheet {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  year          Int
  driveFileId   String
  spreadsheetId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, year])
}

model Category {
  id            String        @id @default(cuid())
  name          String
  code          String
  deductionRate Float
  proofRequired Boolean       @default(true)
  isDefault     Boolean       @default(false)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  transactions  Transaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, code])
}

model Transaction {
  id               String          @id @default(cuid())
  type             TransactionType
  date             DateTime
  amount           Float
  description      String?
  categoryId       String?
  category         Category?       @relation(fields: [categoryId], references: [id])
  deductionRate    Float?
  deductibleAmount Float?
  proofUrl         String?
  proofFileName    String?
  proofDriveId     String?
  fiscalYear       Int
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  trip             Trip?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model TripRate {
  id        String   @id @default(cuid())
  ratePerKm Float
  validFrom DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  trips     Trip[]
  createdAt DateTime @default(now())

  @@index([userId, validFrom])
}

model Trip {
  id            String       @id @default(cuid())
  date          DateTime
  departure     String       @default("Domicile")
  destination   String
  km            Float
  roundTrip     Boolean      @default(false)
  purpose       String
  ratePerKm     Float
  indemnity     Float
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  tripRateId    String
  tripRate      TripRate     @relation(fields: [tripRateId], references: [id])
  fiscalYear    Int
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId, fiscalYear])
}

enum TransactionType {
  EXPENSE
  INCOME
}
