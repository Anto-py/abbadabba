generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  image        String?
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  categories   Category[]
}

model Category {
  id            String        @id @default(cuid())
  name          String
  code          String
  deductionRate Float
  proofRequired Boolean       @default(true)
  isDefault     Boolean       @default(false)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  transactions  Transaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, code])
}

model Transaction {
  id               String          @id @default(cuid())
  type             TransactionType
  date             DateTime
  amount           Float
  description      String?
  categoryId       String?
  category         Category?       @relation(fields: [categoryId], references: [id])
  deductionRate    Float?
  deductibleAmount Float?
  proofUrl         String?
  proofFileName    String?
  proofDriveId     String?
  fiscalYear       Int
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

enum TransactionType {
  EXPENSE
  INCOME
}
